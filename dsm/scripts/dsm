#!/usr/bin/env bash
set -euo pipefail

resolve_source_path() {
  local src="${BASH_SOURCE[0]}"
  while [[ -L "$src" ]]; do
    local dir
    dir="$(cd -- "$(dirname -- "$src")" && pwd)"
    src="$(readlink -- "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  cd -- "$(dirname -- "$src")" && pwd
}

SCRIPT_DIR="$(resolve_source_path)"
REPO_ROOT="${MSR_REPO_ROOT:-$(cd -- "$SCRIPT_DIR/../.." && pwd)}"
BIN_DIR="${MSR_BIN_DIR:-$REPO_ROOT/zig-out/bin}"
MSR_BIN="$BIN_DIR/msr"
VPTY_BIN="$BIN_DIR/vpty"
ALT_BIN="$BIN_DIR/alt"
WSM_MENU_BIN="$REPO_ROOT/wsm/scripts/wsm_menu"

err() { printf '%s\n' "$*" >&2; }
out() { printf '%s\n' "$*"; }

usage() {
  cat <<'EOF2'
NAME
  dsm - directory session manager

USAGE
  [MSR_SESSION=<path>] dsm [--cwd <path>] <command> [args]

COMMANDS
  c, create [-a|--attach] <name> [-- <cmd...>]  create a named local session
  a, attach <name>                              attach to a named local session
  d, detach                                     detach the current session
  current                                       print the current session name
  f, first | l, last | p, prev | n, next        lexical navigation within the directory
  terminate [name] [signal]                     send TERM, INT, or KILL to a session
  wait [name]                                   wait for session exit
  s, status [name]                              print session status
  e, exists [name]                              test whether a session is reachable
  ls, list                                      list session names
  help                                          show this help

DIRECTORY
  dsm resolves names as <directory>/<name>.msr

  The effective directory comes from:
    1. --cwd <path>
    2. the current MSR_SESSION directory
    3. the shell current directory

CONTEXT
  If MSR_SESSION is set, omitted [name] arguments resolve to the current session.
  In-session navigation commands like attach/detach/prev/next operate in nested mode.

HELP
  Run `dsm` or `dsm --help` for this screen.
EOF2
}

nested_usage() {
  local current_name="$1"
  local current_sock="$2"
  cat <<EOF2
SESSION
  $current_name

SOCKET
  $current_sock

EOF2
  usage
}

CWD_OVERRIDE=""
if [[ $# -ge 1 && "$1" == --cwd=* ]]; then
  CWD_OVERRIDE="${1#--cwd=}"
  shift
elif [[ $# -ge 2 && "$1" == "--cwd" ]]; then
  CWD_OVERRIDE="$2"
  shift 2
fi

resolve_dir() {
  if [[ -n "$CWD_OVERRIDE" ]]; then
    printf '%s\n' "$CWD_OVERRIDE"
    return
  fi
  if [[ -n "${MSR_SESSION:-}" ]]; then
    dirname -- "$MSR_SESSION"
    return
  fi
  pwd
}

DIR="$(resolve_dir)"
[[ -d "$DIR" ]] || { err "dsm: directory does not exist: $DIR"; exit 1; }

resolve_current_name() {
  if [[ -n "${MSR_SESSION:-}" ]]; then
    local base
    base="$(basename -- "$MSR_SESSION")"
    printf '%s\n' "${base%.msr}"
    return
  fi
  return 1
}

resolve_name() {
  if [[ $# -ge 1 && -n "${1:-}" && "$1" != --* ]]; then
    printf '%s\n' "$1"
    return
  fi
  resolve_current_name
}

sock_for() {
  local name="$1"
  printf '%s/%s.msr\n' "$DIR" "$name"
}

require_name() {
  local resolved
  resolved="$(resolve_name "${1:-}")" || {
    err "dsm: no target session and no MSR_SESSION context"
    exit 1
  }
  printf '%s\n' "$resolved"
}

list_names() {
  shopt -s nullglob
  local names=()
  local f base
  for f in "$DIR"/*.msr; do
    base="$(basename -- "$f")"
    names+=("${base%.msr}")
  done
  if [[ ${#names[@]} -eq 0 ]]; then
    return 0
  fi
  printf '%s\n' "${names[@]}" | LC_ALL=C sort
}

require_current_context() {
  resolve_current_name >/dev/null 2>&1 || {
    err "dsm: command requires current session context"
    exit 1
  }
}

launch_stack_argv() {
  local -a argv
  argv=("$ALT_BIN")
  if [[ -n "${WSM_MENU_KEY:-}" ]]; then
    argv+=(--key "$WSM_MENU_KEY")
  fi
  argv+=(--run "$WSM_MENU_BIN" --signal-2 TERM -- "$VPTY_BIN" --)
  printf '%s\n' "${argv[@]}"
}

create_session() {
  local sock="$1"
  shift || true
  local -a launch_stack
  mapfile -t launch_stack < <(launch_stack_argv)

  if [[ $# -gt 0 ]]; then
    env WSM_ROOT="${WSM_ROOT:-}" "$MSR_BIN" create -a "$sock" -- "${launch_stack[@]}" "$@"
  else
    env WSM_ROOT="${WSM_ROOT:-}" "$MSR_BIN" create -a "$sock" -- "${launch_stack[@]}" "$SHELL" -i
  fi
}

attach_name() {
  local name="$1"
  local sock nested=0
  sock="$(sock_for "$name")"
  if [[ -n "${MSR_SESSION:-}" ]]; then
    nested=1
  fi
  if "$MSR_BIN" status "$sock" >/dev/null 2>&1; then
    if [[ $nested -eq 1 ]]; then
      "$MSR_BIN" attach "$sock"
    else
      "$MSR_BIN" attach "$sock" --force
    fi
  else
    create_session "$sock"
  fi
}

ordered_name_at() {
  local index="$1"
  mapfile -t names < <(list_names)
  [[ ${#names[@]} -gt 0 ]] || return 1
  [[ $index -ge 0 && $index -lt ${#names[@]} ]] || return 1
  printf '%s\n' "${names[$index]}"
}

ordered_last_name() {
  mapfile -t names < <(list_names)
  [[ ${#names[@]} -gt 0 ]] || return 1
  printf '%s\n' "${names[$((${#names[@]} - 1))]}"
}

ordered_prev_name() {
  local current
  current="$(resolve_current_name)" || return 1
  mapfile -t names < <(list_names)
  [[ ${#names[@]} -gt 0 ]] || return 1
  local i last
  last=$((${#names[@]} - 1))
  for ((i=0; i<${#names[@]}; i++)); do
    if [[ "${names[$i]}" == "$current" ]]; then
      if [[ $i -gt 0 ]]; then
        printf '%s\n' "${names[$((i-1))]}"
      else
        printf '%s\n' "${names[$last]}"
      fi
      return 0
    fi
  done
  return 1
}

ordered_next_name() {
  local current
  current="$(resolve_current_name)" || return 1
  mapfile -t names < <(list_names)
  [[ ${#names[@]} -gt 0 ]] || return 1
  local i last
  last=$((${#names[@]} - 1))
  for ((i=0; i<${#names[@]}; i++)); do
    if [[ "${names[$i]}" == "$current" ]]; then
      if [[ $i -lt $last ]]; then
        printf '%s\n' "${names[$((i+1))]}"
      else
        printf '%s\n' "${names[0]}"
      fi
      return 0
    fi
  done
  return 1
}

if [[ $# -lt 1 ]]; then
  if cname="$(resolve_current_name 2>/dev/null)"; then
    nested_usage "$cname" "${MSR_SESSION:-}"
  else
    usage
  fi
  exit 1
fi

cmd="$1"
shift || true

case "$cmd" in
  help|-h|--help)
    if cname="$(resolve_current_name 2>/dev/null)"; then
      nested_usage "$cname" "${MSR_SESSION:-}"
    else
      usage
    fi
    ;;

  c|create)
    attach_now=0
    if [[ ${1:-} == "-a" || ${1:-} == "--attach" ]]; then
      attach_now=1
      shift || true
    fi
    name="$(require_name "${1:-}")"
    shift || true
    [[ "$name" != *"/"* ]] || { err "dsm: session name must not contain '/'"; exit 1; }
    sock="$(sock_for "$name")"

    if [[ $attach_now -ne 1 ]]; then
      err "dsm: create currently requires -a|--attach so the managed stack starts attached"
      exit 1
    fi

    if [[ ${1:-} == -- ]]; then
      shift || true
      if [[ $# -lt 1 ]]; then
        err "dsm: expected command after --"
        exit 1
      fi
      create_session "$sock" "$@"
    else
      create_session "$sock"
    fi
    ;;

  a|attach)
    name="$(require_name "${1:-}")"
    if [[ $# -ge 1 && "$1" != --* ]]; then shift; fi
    attach_name "$name"
    ;;

  d|detach)
    "$MSR_BIN" detach
    ;;

  current)
    name="$(require_name)"
    out "$name"
    ;;

  f|first)
    target="$(ordered_name_at 0)" || { err "dsm: no sessions in directory"; exit 1; }
    if current="$(resolve_current_name 2>/dev/null)" && [[ "$current" == "$target" ]]; then
      err "dsm: already at first session"
      exit 1
    fi
    attach_name "$target"
    ;;

  l|last)
    target="$(ordered_last_name)" || { err "dsm: no sessions in directory"; exit 1; }
    if current="$(resolve_current_name 2>/dev/null)" && [[ "$current" == "$target" ]]; then
      err "dsm: already at last session"
      exit 1
    fi
    attach_name "$target"
    ;;

  p|prev)
    require_current_context
    target="$(ordered_prev_name)" || { err "dsm: no sessions in directory"; exit 1; }
    attach_name "$target"
    ;;

  n|next)
    require_current_context
    target="$(ordered_next_name)" || { err "dsm: no sessions in directory"; exit 1; }
    attach_name "$target"
    ;;

  terminate)
    name="$(require_name "${1:-}")"
    if [[ $# -ge 1 && "$1" != --* ]]; then shift; fi
    case "${1:-}" in
      "") sig="" ;;
      TERM|INT|KILL) sig="$1" ;;
      -f|--force) sig="KILL" ;;
      *) err "dsm: terminate only accepts TERM, INT, KILL, or --force"; exit 1 ;;
    esac
    if [[ -n "$sig" ]]; then
      "$MSR_BIN" terminate "$(sock_for "$name")" "$sig"
    else
      "$MSR_BIN" terminate "$(sock_for "$name")"
    fi
    ;;

  wait)
    name="$(require_name "${1:-}")"
    "$MSR_BIN" wait "$(sock_for "$name")"
    ;;

  status)
    name="$(require_name "${1:-}")"
    status_out="$($MSR_BIN status "$(sock_for "$name")")"
    printf '%s\n' "$status_out"
    ;;

  exists)
    name="$(require_name "${1:-}")"
    "$MSR_BIN" exists "$(sock_for "$name")"
    ;;

  ls|list)
    list_names
    ;;

  *)
    err "dsm: unknown command: $cmd"
    usage
    exit 1
    ;;
esac
