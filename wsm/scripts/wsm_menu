#!/usr/bin/env bash
set -euo pipefail

resolve_source_path() {
  local src="${BASH_SOURCE[0]}"
  while [[ -L "$src" ]]; do
    local dir
    dir="$(cd -- "$(dirname -- "$src")" && pwd)"
    src="$(readlink -- "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  cd -- "$(dirname -- "$src")" && pwd
}

SCRIPT_DIR="$(resolve_source_path)"
if [[ -x "$SCRIPT_DIR/wsm" ]]; then
  WSM_BIN="${WSM_BIN:-$SCRIPT_DIR/wsm}"
  REPO_ROOT="${MSR_REPO_ROOT:-}"
else
  REPO_ROOT="${MSR_REPO_ROOT:-$(cd -- "$SCRIPT_DIR/../.." && pwd)}"
  WSM_BIN="${WSM_BIN:-$REPO_ROOT/wsm/scripts/wsm}"
fi

tty_printf() { printf "$@" > /dev/tty; }
err() { tty_printf '%s\n' "$*"; }
out() { tty_printf '%s\n' "$*"; }

menu_key_value() {
  if [[ -n "${WSM_MENU_KEY:-}" ]]; then
    printf '%s\n' "$WSM_MENU_KEY"
  else
    printf '%s\n' 'ctrl-g'
  fi
}

ROOT_OVERRIDE=""

if [[ $# -ge 1 && "$1" == --root=* ]]; then
  ROOT_OVERRIDE="${1#--root=}"
  shift
elif [[ $# -ge 2 && "$1" == "--root" ]]; then
  ROOT_OVERRIDE="$2"
  shift 2
fi

wsm_cmd() {
  if [[ -n "$ROOT_OVERRIDE" ]]; then
    "$WSM_BIN" --root "$ROOT_OVERRIDE" "$@"
  else
    "$WSM_BIN" "$@"
  fi
}

CURRENT_ROOT=""
CURRENT_SESSION=""

read_key() {
  local key
  IFS= read -rsn1 key < /dev/tty || return 1

  if [[ "$key" == $'\e' ]]; then
    local rest=""
    IFS= read -rsn1 -t 0.01 rest < /dev/tty || true
    if [[ -n "$rest" ]]; then
      key+="$rest"
      while IFS= read -rsn1 -t 0.001 rest < /dev/tty; do
        key+="$rest"
      done
    fi
  fi

  printf '%s' "$key"
}

prompt_line() {
  local prompt="$1"
  local __outvar="${2:-}"
  local buf=""
  local key

  while true; do
    tty_printf '\r\033[2K%s%s' "$prompt" "$buf"
    key="$(read_key)" || return 1

    case "$key" in
      ''|$'\n'|$'\r')
        tty_printf '\n'
        if [[ -n "$__outvar" ]]; then
          printf -v "$__outvar" '%s' "$buf"
        else
          printf '%s' "$buf"
        fi
        return 0
        ;;
      $'\e')
        tty_printf '\n'
        return 130
        ;;
      $'\177'|$'\010')
        if [[ -n "$buf" ]]; then
          buf="${buf%?}"
        fi
        ;;
      $'\e['*)
        ;;
      [[:print:]])
        buf+="$key"
        ;;
    esac
  done
}

wait_back() {
  tty_printf '\nesc to go back... '
  while true; do
    local key
    key="$(read_key)" || return 0
    case "$key" in
      $'\e'|$'\n'|$'\r')
        tty_printf '\n'
        return 0
        ;;
    esac
  done
}

pause() {
  wait_back
}

refresh_context() {
  CURRENT_ROOT="${ROOT_OVERRIDE:-${WSM_ROOT:-$PWD}}"

  if current="$(wsm_cmd current 2>/dev/null)"; then
    CURRENT_SESSION="$current"
  else
    CURRENT_SESSION=""
  fi
}

clear_screen() {
  tty_printf '\033[H\033[2J'
}

list_ids() {
  wsm_cmd list
}

canonical_id_is_valid() {
  local id="$1"
  [[ -n "$id" ]] || return 1
  [[ "$id" != -* ]] || return 1
  [[ "$id" != /* ]] || return 1
  [[ "$id" != */ ]] || return 1
  [[ "$id" != *//* ]] || return 1
  [[ "$id" != *"/./"* ]] || return 1
  [[ "$id" != *"/../"* ]] || return 1
  [[ "$id" != "." ]] || return 1
  [[ "$id" != ".." ]] || return 1
  [[ "$id" != ./* ]] || return 1
  [[ "$id" != ../* ]] || return 1
  [[ "$id" != */. ]] || return 1
  [[ "$id" != */.. ]] || return 1
  return 0
}

preview_nav() {
  local op="$1"
  [[ -n "$CURRENT_SESSION" ]] || return 1
  local target
  target="$(wsm_cmd resolve "$op" 2>/dev/null || true)"
  [[ -n "$target" ]] || return 1
  printf '%s\n' "$target"
}

# render_nav_line() {
#   local key="$1"
#   local label="$2"
#   local op="$3"
#   local desc="$4"
#   local target
#   if target="$(preview_nav "$op")"; then
#     tty_printf '[%s] %s: %s -> %s\n' "$key" "$label" "$desc" "$target"
#   else
#     tty_printf '[%s] %s: %s\n' "$key" "$label" "$desc"
#   fi
# }
#
render_nav_line() {
  local key="$1"
  local label="$2"
  local op="$3"
  local desc="$4"
  local target

  if target="$(preview_nav "$op")"; then
    # Skip if no target or target matches CURRENT_SESSION
    if [[ -z "$target" || "$target" == "$CURRENT_SESSION" ]]; then
      return
    fi

    tty_printf '[%s] %s: %s -> %s\n' "$key" "$label" "$desc" "$target"
  fi
}


render_header() {
  clear_screen
  tty_printf 'WSM MENU\n'
  tty_printf '========\n\n'
  tty_printf 'workspace root: %s\n' "$CURRENT_ROOT"
  if [[ -n "$CURRENT_SESSION" ]]; then
    tty_printf 'current session: %s\n' "$CURRENT_SESSION"
  else
    tty_printf 'current session: none\n'
  fi
  tty_printf 'hotkey: %s\n' "$(menu_key_value)"
  tty_printf '\n'
}

render_menu() {
  tty_printf '[a] attach: search and switch to a different session within workspace\n'
  tty_printf '[c] create: create new session within workspace and immediately attach\n'
  tty_printf '[d] detach: detach from current session\n'
  tty_printf '[g] log: view history for current session\n'
  tty_printf '[s] list: list all sessions within workspace\n'
  tty_printf '[h] help: prints wsm manual\n\n'
  render_nav_line 'f' 'first' 'first' 'Jump to first session'
  render_nav_line 'l' 'last' 'last' 'Jump to last session'
  render_nav_line 'n' 'next' 'next' 'Jump to next session'
  render_nav_line 'p' 'prev' 'prev' 'Jump to previous session'
  render_nav_line 'i' 'in' 'in' 'Jump child session'
  render_nav_line 'o' 'out' 'out' 'Jump parent session'
  tty_printf '\n[esc] exit this menu\n'
  tty_printf '\n'
}

filter_matches() {
  local query="$1"
  local id base
  local -a exact_ids=() exact_bases=() prefix_ids=() prefix_bases=()
  FILTER_MATCHES=()
  FILTER_EXACT_MATCH=0

  for id in "${ALL_IDS[@]}"; do
    base="${id##*/}"

    if [[ -n "$query" && "$id" == "$query" ]]; then
      exact_ids+=("$id")
      FILTER_EXACT_MATCH=1
      continue
    fi
    if [[ -n "$query" && "$base" == "$query" ]]; then
      exact_bases+=("$id")
      continue
    fi
    if [[ -z "$query" || "$id" == "$query"* ]]; then
      prefix_ids+=("$id")
      continue
    fi
    if [[ "$base" == "$query"* ]]; then
      prefix_bases+=("$id")
      continue
    fi
  done

  FILTER_MATCHES=("${exact_ids[@]}" "${exact_bases[@]}" "${prefix_ids[@]}" "${prefix_bases[@]}")
}

render_match_list() {
  local selection="${1:-0}"
  local selectable="${2:-1}"
  local -a visible=()
  local limit=${#FILTER_MATCHES[@]}
  local i

  if (( limit > 10 )); then
    limit=10
  fi
  for ((i=0; i<limit; i++)); do
    visible+=("${FILTER_MATCHES[$i]}")
  done

  if (( ${#FILTER_MATCHES[@]} == 0 )); then
    tty_printf '  no matches\n'
    return
  fi

  for ((i=0; i<${#visible[@]}; i++)); do
    if (( selectable == 1 && i == selection )); then
      tty_printf '> %s\n' "${visible[$i]}"
    else
      tty_printf '  %s\n' "${visible[$i]}"
    fi
  done
  if (( ${#FILTER_MATCHES[@]} > 10 )); then
    tty_printf '\n  ... %d more\n' "$((${#FILTER_MATCHES[@]} - 10))"
  fi
}

common_prefix() {
  local prefix="$1"
  shift || true
  local candidate i max

  for candidate in "$@"; do
    max=${#prefix}
    if (( ${#candidate} < max )); then
      max=${#candidate}
    fi
    for ((i=0; i<max; i++)); do
      [[ "${prefix:i:1}" == "${candidate:i:1}" ]] || {
        prefix="${prefix:0:i}"
        break
      }
    done
    if (( i == max )); then
      prefix="${prefix:0:max}"
    fi
  done

  printf '%s' "$prefix"
}

apply_tab_completion() {
  local query="$1"
  local id
  local -a candidates=()

  [[ -n "$query" ]] || return 1

  for id in "${ALL_IDS[@]}"; do
    [[ "$id" == "$query"* ]] || continue
    candidates+=("$id")
  done

  (( ${#candidates[@]} > 0 )) || return 1

  local completion
  completion="$(common_prefix "${candidates[0]}" "${candidates[@]:1}")"
  [[ -n "$completion" && "$completion" != "$query" ]] || return 1

  printf '%s' "$completion"
}

attach_flow() {
  local query=""
  local selection=0
  local key
  mapfile -t ALL_IDS < <(list_ids)

  while true; do
    filter_matches "$query"

    # Lift CURRENT_SESSION to top when query is empty
    if [[ -z "$query" && -n "$CURRENT_SESSION" ]]; then
      local new=()
      for id in "${FILTER_MATCHES[@]}"; do
        [[ "$id" == "$CURRENT_SESSION" ]] || new+=("$id")
      done

      if printf '%s\n' "${ALL_IDS[@]}" | grep -qx "$CURRENT_SESSION"; then
        FILTER_MATCHES=("$CURRENT_SESSION" "${new[@]}")
      else
        FILTER_MATCHES=("${new[@]}")
      fi
    fi

    if (( ${#FILTER_MATCHES[@]} == 0 )); then
      selection=0
    else
      (( selection >= ${#FILTER_MATCHES[@]} )) && selection=$((${#FILTER_MATCHES[@]} - 1))
      (( selection < 0 )) && selection=0
    fi

    render_header
    tty_printf 'ATTACH\n'
    tty_printf '%s\n\n' '----'
    tty_printf 'Type session name to narrow search. Enter attaches selection.\n'
    tty_printf 'Arrow up/down changes selection. Esc goes back.\n'
    tty_printf 'Tab to auto complete search query.\n\n'
    tty_printf 'Sessions:\n'

    # --- Move match list ABOVE the prompt ---
    render_match_list "$selection" 1
    tty_printf '\n'

    # --- Print search prompt LAST so cursor stays here ---
    tty_printf 'search> %s' "$query"

    key="$(read_key)" || return 0
    case "$key" in
      ''|$'\n'|$'\r')
        if (( ${#FILTER_MATCHES[@]} > 0 )); then
          wsm_cmd attach "${FILTER_MATCHES[$selection]}"
          return 10
        fi
        ;;
      $'\e')
        if [[ -n "$query" ]]; then
          query=""
          selection=0
        else
          return 0
        fi
        ;;
      $'\e[A') (( ${#FILTER_MATCHES[@]} > 0 && selection > 0 )) && selection=$((selection - 1)) ;;
      $'\e[B') (( ${#FILTER_MATCHES[@]} > 0 && selection + 1 < ${#FILTER_MATCHES[@]} && selection + 1 < 10 )) && selection=$((selection + 1)) ;;
      $'\177'|$'\010') [[ -n "$query" ]] && query="${query%?}" && selection=0 ;;
      $'\t')
        completed="$(apply_tab_completion "$query" || true)"
        if [[ -n "$completed" ]]; then
          query="$completed"
          selection=0
        fi
        ;;
      $'\e['*) ;;
      [[:print:]]) query+="$key"; selection=0 ;;
    esac
  done
}

