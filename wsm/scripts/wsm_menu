first_flow() {
  if [[ -z "$CURRENT_SESSION" ]]; then
    tty_printf '\nno current session for first\n'
    pause
    return 1
  fi
  wsm_cmd first
}

last_flow() {
  if [[ -z "$CURRENT_SESSION" ]]; then
    tty_printf '\nno current session for last\n'
    pause
    return 1
  fi
  wsm_cmd last
}

next_flow() {
  if [[ -z "$CURRENT_SESSION" ]]; then
    tty_printf '\nno current session for next\n'
    pause
    return 1
  fi
  wsm_cmd next
}

prev_flow() {
  if [[ -z "$CURRENT_SESSION" ]]; then
    tty_printf '\nno current session for prev\n'
    pause
    return 1
  fi
  wsm_cmd prev
}

log_flow() {
  if [[ -z "$CURRENT_SESSION" ]]; then
    tty_printf '\nno current session for log\n'
    pause
    return 1
  fi
  wsm_cmd log "$CURRENT_SESSION"
}

detach_flow() {
  if [[ -z "$CURRENT_SESSION" ]]; then
    tty_printf '\nno current session to detach\n'
    pause
    return 1
  fi
  wsm_cmd detach
}

list_flow() {
  render_header
  tty_printf '%s\n' 'LIST'
  tty_printf '%s\n\n' '----'
  if ! list_ids > /dev/tty; then
    tty_printf '%s\n' 'no sessions found'
  fi
  tty_printf '\n'
  pause
}

in_flow() {
  if [[ -z "$CURRENT_SESSION" ]]; then
    tty_printf '\nno current session for in\n'
    pause
    return 1
  fi
  wsm_cmd in
}

out_flow() {
  if [[ -z "$CURRENT_SESSION" ]]; then
    tty_printf '\nno current session for out\n'
    pause
    return 1
  fi
  wsm_cmd out
}

help_flow() {
  render_header
  wsm_cmd help > /dev/tty
  tty_printf '\n'
  pause
}

main_loop() {
  local choice
  while true; do
    refresh_context
    render_header
    render_menu
    tty_printf 'choice> '
    choice="$(read_key)" || exit 0
    tty_printf '\n'

    case "$choice" in
      $'\e')
        exit 0
        ;;
      [Aa])
        attach_flow
        rc=$?
        if (( rc == 10 )); then
          exit 0
        elif (( rc != 0 )); then
          exit "$rc"
        fi
        ;;
      [Cc])
        create_flow
        rc=$?
        if (( rc == 10 )); then
          exit 0
        elif (( rc != 0 )); then
          exit "$rc"
        fi
        ;;
      [Ff]) first_flow; exit $? ;;
      [Ll]) last_flow; exit $? ;;
      [Nn]) next_flow; exit $? ;;
      [Pp]) prev_flow; exit $? ;;
      [Ii]) in_flow; exit $? ;;
      [Oo]) out_flow; exit $? ;;
      [Dd]) detach_flow; exit $? ;;
      [Gg]) log_flow; exit $? ;;
      [Ss]) list_flow ;;
      [HhMm]) help_flow ;;
      [Qq]) exit 0 ;;
      '') ;;
      *) ;;
    esac
  done
}

main_loop
