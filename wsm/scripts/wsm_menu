create_flow() {
  local query=""
  local key
  local can_create=0
  local invalid_hint=""
  mapfile -t ALL_IDS < <(list_ids)

  while true; do
    filter_matches "$query"
    can_create=0
    invalid_hint=""

    if [[ -n "$query" ]]; then
      if canonical_id_is_valid "$query"; then
        if [[ $FILTER_EXACT_MATCH -eq 0 ]]; then
          can_create=1
        fi
      else
        invalid_hint='Cannot start or end with /'
      fi
    fi

    render_header
    tty_printf 'CREATE\n'
    tty_printf '%s\n\n' '----'
    tty_printf 'Create a new session. Esc goes back, Enter creates.\n'
    tty_printf 'You can create child sessions by using forward slash, eg. work/project1. \n\n'

    # Show errors/hints *before* the prompt
    if (( can_create == 1 )); then
      tty_printf 'Enter to create -> %s\n\n' "$query"
    elif [[ -n "$invalid_hint" ]]; then
      tty_printf '%s\n\n' "$invalid_hint"
    elif [[ -n "$query" && $FILTER_EXACT_MATCH -eq 1 ]]; then
      tty_printf 'Already exists: %s\n\n' "$query"
    else
      tty_printf '\n'
    fi

    # Print prompt LAST so cursor stays here
    tty_printf 'session name> %s' "$query"


    key="$(read_key)" || return 0
    case "$key" in
      ''|$'\n'|$'\r')
        if (( can_create == 1 )); then
          wsm_cmd create "$query"
          return 10
        fi
        ;;
      $'\e')
        if [[ -n "$query" ]]; then
          query=""
        else
          return 0
        fi
        ;;
      $'\177'|$'\010') [[ -n "$query" ]] && query="${query%?}" ;;
      $'\e['*) ;;
      [[:print:]]) query+="$key" ;;
    esac
  done
}

