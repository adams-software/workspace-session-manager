#!/usr/bin/env bash
set -euo pipefail

resolve_source_path() {
  local src="${BASH_SOURCE[0]}"
  while [[ -L "$src" ]]; do
    local dir
    dir="$(cd -- "$(dirname -- "$src")" && pwd)"
    src="$(readlink -- "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  cd -- "$(dirname -- "$src")" && pwd
}

SCRIPT_DIR="$(resolve_source_path)"
REPO_ROOT="${MSR_REPO_ROOT:-$(cd -- "$SCRIPT_DIR/../.." && pwd)}"
WSM_BIN="$REPO_ROOT/wsm/scripts/wsm"

tty_printf() { printf "$@" > /dev/tty; }
err() { tty_printf '%s\n' "$*"; }
out() { tty_printf '%s\n' "$*"; }

ROOT_OVERRIDE=""

if [[ $# -ge 1 && "$1" == --root=* ]]; then
  ROOT_OVERRIDE="${1#--root=}"
  shift
elif [[ $# -ge 2 && "$1" == "--root" ]]; then
  ROOT_OVERRIDE="$2"
  shift 2
fi

wsm_cmd() {
  if [[ -n "$ROOT_OVERRIDE" ]]; then
    "$WSM_BIN" --root "$ROOT_OVERRIDE" "$@"
  else
    "$WSM_BIN" "$@"
  fi
}

CURRENT_ROOT=""
CURRENT_SESSION=""

read_key() {
  local key
  IFS= read -rsn1 key < /dev/tty || return 1

  if [[ "$key" == $'\e' ]]; then
    local rest=""
    IFS= read -rsn1 -t 0.01 rest < /dev/tty || true
    if [[ -n "$rest" ]]; then
      key+="$rest"
      while IFS= read -rsn1 -t 0.001 rest < /dev/tty; do
        key+="$rest"
      done
    fi
  fi

  printf '%s' "$key"
}

prompt_line() {
  local prompt="$1"
  local __outvar="${2:-}"
  local buf=""
  local key

  while true; do
    tty_printf '\r\033[2K%s%s' "$prompt" "$buf"
    key="$(read_key)" || return 1

    case "$key" in
      ''|$'\n'|$'\r')
        tty_printf '\n'
        if [[ -n "$__outvar" ]]; then
          printf -v "$__outvar" '%s' "$buf"
        else
          printf '%s' "$buf"
        fi
        return 0
        ;;
      $'\e')
        tty_printf '\n'
        return 130
        ;;
      $'\177'|$'\010')
        if [[ -n "$buf" ]]; then
          buf="${buf%?}"
        fi
        ;;
      $'\e['*)
        ;;
      [[:print:]])
        buf+="$key"
        ;;
    esac
  done
}

wait_back() {
  tty_printf '\n[enter/esc] back... '
  while true; do
    local key
    key="$(read_key)" || return 0
    case "$key" in
      $'\e'|$'\n'|$'\r')
        tty_printf '\n'
        return 0
        ;;
    esac
  done
}

pause() {
  wait_back
}

refresh_context() {
  CURRENT_ROOT="${ROOT_OVERRIDE:-${WSM_ROOT:-$PWD}}"

  if current="$(wsm_cmd current 2>/dev/null)"; then
    CURRENT_SESSION="$current"
  else
    CURRENT_SESSION=""
  fi
}

clear_screen() {
  tty_printf '\033[H\033[2J'
}

list_ids() {
  wsm_cmd list
}

canonical_id_is_valid() {
  local id="$1"
  [[ -n "$id" ]] || return 1
  [[ "$id" != -* ]] || return 1
  [[ "$id" != /* ]] || return 1
  [[ "$id" != */ ]] || return 1
  [[ "$id" != *//* ]] || return 1
  [[ "$id" != *"/./"* ]] || return 1
  [[ "$id" != *"/../"* ]] || return 1
  [[ "$id" != "." ]] || return 1
  [[ "$id" != ".." ]] || return 1
  [[ "$id" != ./* ]] || return 1
  [[ "$id" != ../* ]] || return 1
  [[ "$id" != */. ]] || return 1
  [[ "$id" != */.. ]] || return 1
  return 0
}

preview_nav() {
  local op="$1"
  [[ -n "$CURRENT_SESSION" ]] || return 1
  local target
  target="$(wsm_cmd resolve "$op" 2>/dev/null || true)"
  [[ -n "$target" ]] || return 1
  printf '%s\n' "$target"
}

render_nav_line() {
  local key="$1"
  local label="$2"
  local op="$3"
  local target
  if target="$(preview_nav "$op")"; then
    tty_printf '[%s] %s -> %s\n' "$key" "$label" "$target"
  else
    tty_printf '[%s] %s\n' "$key" "$label"
  fi
}

render_header() {
  clear_screen
  tty_printf 'WSM MENU\n'
  tty_printf '========\n\n'
  tty_printf 'root: %s\n' "$CURRENT_ROOT"
  if [[ -n "$CURRENT_SESSION" ]]; then
    tty_printf 'current: %s\n' "$CURRENT_SESSION"
  else
    tty_printf 'current: none\n'
  fi
  tty_printf '\n'
}

render_menu() {
  tty_printf '[a] attach\n'
  tty_printf '[c] create\n'
  render_nav_line 'f' 'first' 'first'
  render_nav_line 'l' 'last' 'last'
  render_nav_line 'n' 'next' 'next'
  render_nav_line 'p' 'prev' 'prev'
  render_nav_line 'i' 'in' 'in'
  render_nav_line 'o' 'out' 'out'
  tty_printf '[d] detach\n'
  tty_printf '[s] list\n'
  tty_printf '[h] help\n'
  tty_printf '[q] quit\n'
  tty_printf '\n'
}

filter_matches() {
  local query="$1"
  local id base
  local -a exact_ids=() exact_bases=() prefix_ids=() prefix_bases=()
  FILTER_MATCHES=()
  FILTER_EXACT_MATCH=0

  for id in "${ALL_IDS[@]}"; do
    base="${id##*/}"

    if [[ -n "$query" && "$id" == "$query" ]]; then
      exact_ids+=("$id")
      FILTER_EXACT_MATCH=1
      continue
    fi
    if [[ -n "$query" && "$base" == "$query" ]]; then
      exact_bases+=("$id")
      continue
    fi
    if [[ -z "$query" || "$id" == "$query"* ]]; then
      prefix_ids+=("$id")
      continue
    fi
    if [[ "$base" == "$query"* ]]; then
      prefix_bases+=("$id")
      continue
    fi
  done

  FILTER_MATCHES=("${exact_ids[@]}" "${exact_bases[@]}" "${prefix_ids[@]}" "${prefix_bases[@]}")
}

render_match_list() {
  local selection="${1:-0}"
  local selectable="${2:-1}"
  local -a visible=()
  local limit=${#FILTER_MATCHES[@]}
  local i

  if (( limit > 10 )); then
    limit=10
  fi
  for ((i=0; i<limit; i++)); do
    visible+=("${FILTER_MATCHES[$i]}")
  done

  if (( ${#FILTER_MATCHES[@]} == 0 )); then
    tty_printf '  no matches\n'
    return
  fi

  for ((i=0; i<${#visible[@]}; i++)); do
    if (( selectable == 1 && i == selection )); then
      tty_printf '> %s\n' "${visible[$i]}"
    else
      tty_printf '  %s\n' "${visible[$i]}"
    fi
  done
  if (( ${#FILTER_MATCHES[@]} > 10 )); then
    tty_printf '\n  ... %d more\n' "$((${#FILTER_MATCHES[@]} - 10))"
  fi
}

common_prefix() {
  local prefix="$1"
  shift || true
  local candidate i max

  for candidate in "$@"; do
    max=${#prefix}
    if (( ${#candidate} < max )); then
      max=${#candidate}
    fi
    for ((i=0; i<max; i++)); do
      [[ "${prefix:i:1}" == "${candidate:i:1}" ]] || {
        prefix="${prefix:0:i}"
        break
      }
    done
    if (( i == max )); then
      prefix="${prefix:0:max}"
    fi
  done

  printf '%s' "$prefix"
}

apply_tab_completion() {
  local query="$1"
  local id
  local -a candidates=()

  [[ -n "$query" ]] || return 1

  for id in "${ALL_IDS[@]}"; do
    [[ "$id" == "$query"* ]] || continue
    candidates+=("$id")
  done

  (( ${#candidates[@]} > 0 )) || return 1

  local completion
  completion="$(common_prefix "${candidates[0]}" "${candidates[@]:1}")"
  [[ -n "$completion" && "$completion" != "$query" ]] || return 1

  printf '%s' "$completion"
}

attach_flow() {
  local query=""
  local selection=0
  local key
  mapfile -t ALL_IDS < <(list_ids)

  while true; do
    filter_matches "$query"
    if (( ${#FILTER_MATCHES[@]} == 0 )); then
      selection=0
    else
      (( selection >= ${#FILTER_MATCHES[@]} )) && selection=$((${#FILTER_MATCHES[@]} - 1))
      (( selection < 0 )) && selection=0
    fi

    render_header
    tty_printf 'ATTACH\n'
    tty_printf '%s\n\n' '----'
    tty_printf 'type a session id or basename prefix. enter attaches selection.\n'
    tty_printf 'up/down changes selection. esc goes back.\n\n'
    tty_printf 'search> %s\n\n' "$query"
    render_match_list "$selection" 1
    tty_printf '\n'

    key="$(read_key)" || return 0
    case "$key" in
      ''|$'\n'|$'\r')
        if (( ${#FILTER_MATCHES[@]} > 0 )); then
          wsm_cmd attach "${FILTER_MATCHES[$selection]}"
          return 10
        fi
        ;;
      $'\e')
        if [[ -n "$query" ]]; then
          query=""
          selection=0
        else
          return 0
        fi
        ;;
      $'\e[A') (( ${#FILTER_MATCHES[@]} > 0 && selection > 0 )) && selection=$((selection - 1)) ;;
      $'\e[B') (( ${#FILTER_MATCHES[@]} > 0 && selection + 1 < ${#FILTER_MATCHES[@]} && selection + 1 < 10 )) && selection=$((selection + 1)) ;;
      $'\177'|$'\010') [[ -n "$query" ]] && query="${query%?}" && selection=0 ;;
      $'\t')
        completed="$(apply_tab_completion "$query" || true)"
        if [[ -n "$completed" ]]; then
          query="$completed"
          selection=0
        fi
        ;;
      $'\e['*) ;;
      [[:print:]]) query+="$key"; selection=0 ;;
    esac
  done
}

create_flow() {
  local query=""
  local key
  local can_create=0
  local invalid_hint=""
  mapfile -t ALL_IDS < <(list_ids)

  while true; do
    filter_matches "$query"
    can_create=0
    invalid_hint=""
    if [[ -n "$query" ]]; then
      if canonical_id_is_valid "$query"; then
        if [[ $FILTER_EXACT_MATCH -eq 0 ]]; then
          can_create=1
        fi
      else
        invalid_hint='invalid canonical target'
      fi
    fi

    render_header
    tty_printf 'CREATE\n'
    tty_printf '%s\n\n' '----'
    tty_printf 'type a canonical target. enter creates it when no exact match exists.\n'
    tty_printf 'matches are shown for context only. esc goes back.\n\n'
    tty_printf 'target> %s\n\n' "$query"
    render_match_list 0 0
    if (( can_create == 1 )); then
      tty_printf '\n  create -> %s\n' "$query"
    elif [[ -n "$invalid_hint" ]]; then
      tty_printf '\n  %s\n' "$invalid_hint"
    fi
    tty_printf '\n'

    key="$(read_key)" || return 0
    case "$key" in
      ''|$'\n'|$'\r')
        if [[ -n "$query" && $FILTER_EXACT_MATCH -eq 1 ]]; then
          wsm_cmd attach "$query"
          return 10
        elif (( can_create == 1 )); then
          wsm_cmd create "$query"
          return 10
        fi
        ;;
      $'\e')
        if [[ -n "$query" ]]; then
          query=""
        else
          return 0
        fi
        ;;
      $'\177'|$'\010') [[ -n "$query" ]] && query="${query%?}" ;;
      $'\e['*) ;;
      [[:print:]]) query+="$key" ;;
    esac
  done
}

first_flow() {
  if [[ -z "$CURRENT_SESSION" ]]; then
    tty_printf '\nno current session for first\n'
    pause
    return 1
  fi
  wsm_cmd first
}

last_flow() {
  if [[ -z "$CURRENT_SESSION" ]]; then
    tty_printf '\nno current session for last\n'
    pause
    return 1
  fi
  wsm_cmd last
}

next_flow() {
  if [[ -z "$CURRENT_SESSION" ]]; then
    tty_printf '\nno current session for next\n'
    pause
    return 1
  fi
  wsm_cmd next
}

prev_flow() {
  if [[ -z "$CURRENT_SESSION" ]]; then
    tty_printf '\nno current session for prev\n'
    pause
    return 1
  fi
  wsm_cmd prev
}

detach_flow() {
  if [[ -z "$CURRENT_SESSION" ]]; then
    tty_printf '\nno current session to detach\n'
    pause
    return 1
  fi
  wsm_cmd detach
}

list_flow() {
  render_header
  tty_printf '%s\n' 'LIST'
  tty_printf '%s\n\n' '----'
  if ! list_ids > /dev/tty; then
    tty_printf '%s\n' 'no sessions found'
  fi
  tty_printf '\n'
  pause
}

in_flow() {
  if [[ -z "$CURRENT_SESSION" ]]; then
    tty_printf '\nno current session for in\n'
    pause
    return 1
  fi
  wsm_cmd in
}

out_flow() {
  if [[ -z "$CURRENT_SESSION" ]]; then
    tty_printf '\nno current session for out\n'
    pause
    return 1
  fi
  wsm_cmd out
}

help_flow() {
  render_header
  wsm_cmd help > /dev/tty
  tty_printf '\n'
  pause
}

main_loop() {
  local choice
  while true; do
    refresh_context
    render_header
    render_menu
    tty_printf 'choice> '
    choice="$(read_key)" || exit 0
    tty_printf '\n'

    case "$choice" in
      $'\e')
        exit 0
        ;;
      [Aa])
        attach_flow
        rc=$?
        if (( rc == 10 )); then
          exit 0
        elif (( rc != 0 )); then
          exit "$rc"
        fi
        ;;
      [Cc])
        create_flow
        rc=$?
        if (( rc == 10 )); then
          exit 0
        elif (( rc != 0 )); then
          exit "$rc"
        fi
        ;;
      [Ff]) first_flow; exit $? ;;
      [Ll]) last_flow; exit $? ;;
      [Nn]) next_flow; exit $? ;;
      [Pp]) prev_flow; exit $? ;;
      [Ii]) in_flow; exit $? ;;
      [Oo]) out_flow; exit $? ;;
      [Dd]) detach_flow; exit $? ;;
      [Ss]) list_flow ;;
      [HhMm]) help_flow ;;
      [Qq]) exit 0 ;;
      '') ;;
      *) ;;
    esac
  done
}

main_loop
