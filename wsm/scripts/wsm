#!/usr/bin/env bash
set -euo pipefail

resolve_source_path() {
  local src="${BASH_SOURCE[0]}"
  while [[ -L "$src" ]]; do
    local dir
    dir="$(cd -- "$(dirname -- "$src")" && pwd)"
    src="$(readlink -- "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  cd -- "$(dirname -- "$src")" && pwd
}

SCRIPT_DIR="$(resolve_source_path)"
REPO_ROOT="${MSR_REPO_ROOT:-$(cd -- "$SCRIPT_DIR/../.." && pwd)}"
BIN_DIR="${MSR_BIN_DIR:-$REPO_ROOT/zig-out/bin}"

DSM_BIN="$REPO_ROOT/dsm/scripts/dsm"
MSR_BIN="$BIN_DIR/msr"

err() { printf '%s\n' "$*" >&2; }
out() { printf '%s\n' "$*"; }

usage_body() {
  cat <<'EOU'
NAME
  wsm - workspace session manager

USAGE
  [WSM_ROOT=<path>] wsm [--root <path>] <command> [args]

COMMANDS
  [c]reate <target> [-- <cmd...>]        create and attach to a workspace session
  [a]ttach <target-or-query>             attach to a resolved workspace session
  [d]etach                               detach the current session
  c[u]rrent                              print the current canonical workspace id
  [e]xists [target-or-query]             test whether a session is reachable
  [t]erminate [target-or-query] [signal] send TERM, INT, or KILL to a session
  [f]irst | [l]ast | [p]rev | [n]ext     navigate sessions within the current directory
  [i]n                                   attach to the first lexical direct child session
  [o]ut                                  attach to the exact direct parent session
  ls, li[s]t                             list canonical ids under the workspace root
  [r]oot                                 print the resolved workspace root
  [m]enu                                 open the interactive workspace menu
  [h]elp                                 show this help

ROOT
  wsm requires an explicit workspace root via --root <path> or WSM_ROOT.
  It does not silently fall back to the current directory.

RESOLUTION
  Queries resolve in this order:
    1. exact canonical id match
    2. exact basename match if unique
    3. otherwise print candidates and exit nonzero

HELP
  Run `wsm` or `wsm --help` for this screen.
  Use shell completion for fast canonical-id expansion.
  If you are in a session, you will see it listed under `SESSION:`
EOU
}

usage() {
  usage_body
  cat <<EOF

WORKSPACE:
  $WSM_ROOT_RESOLVED

EOF
}

nested_usage() {
  usage_body
  cat <<EOF

WORKSPACE:
  $WSM_ROOT_RESOLVED
EOF
  local current_id="$1"
  local root="$2"
  cat <<EOF2

SESSION:
  $current_id

EOF2
}

ROOT_OVERRIDE=""
MENU_KEY_OVERRIDE=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --root=*)
      ROOT_OVERRIDE="${1#--root=}"
      shift
      ;;
    --root)
      ROOT_OVERRIDE="$2"
      shift 2
      ;;
    --menu-key=*)
      MENU_KEY_OVERRIDE="${1#--menu-key=}"
      shift
      ;;
    --menu-key)
      MENU_KEY_OVERRIDE="$2"
      shift 2
      ;;
    *)
      break
      ;;
  esac
done

expand_path() {
  local p="${1:-}"
  case "$p" in
    "~") printf '%s\n' "$HOME" ;;
    "~/"*) printf '%s/%s\n' "$HOME" "${p#~/}" ;;
    *) printf '%s\n' "$p" ;;
  esac
}
expand_user_path() {
  local p="${1:-}"
  case "$p" in
    "~")
      p="$HOME"
      ;;
    "~/"*)
      p="$HOME/${p#\~/}"
      ;;
  esac
  printf '%s\n' "$p"
}

normalize_path() {
  local p
  p="$(expand_user_path "${1:-}")"

  if [[ "$p" != /* ]]; then
    p="$PWD/$p"
  fi

  printf '%s\n' "$p"
}

resolve_root() {
  if [[ -n "$ROOT_OVERRIDE" ]]; then
    normalize_path "$ROOT_OVERRIDE"
    return
  fi
  if [[ -n "${WSM_ROOT:-}" ]]; then
    normalize_path "$WSM_ROOT"
    return
  fi
  return 1
}

require_root() {
  err "wsm: workspace root is required"
  err "set WSM_ROOT or pass --root <path>"
  err "example: wsm --root ~/code create -a api/dev -- bash"
  exit 1
}

WSM_ROOT_RESOLVED="$(resolve_root)" || require_root
[[ -d "$WSM_ROOT_RESOLVED" ]] || { err "wsm: root directory does not exist: $WSM_ROOT_RESOLVED"; exit 1; }

canonical_id_for_sock() {
  local sock="$1"
  local rel
  rel="${sock#$WSM_ROOT_RESOLVED/}"
  [[ "$rel" != "$sock" ]] || {
    if [[ "$sock" == "$WSM_ROOT_RESOLVED"/*.msr ]]; then
      rel="$(basename -- "$sock")"
    else
      return 1
    fi
  }
  [[ "$rel" == *.msr ]] || return 1
  printf '%s\n' "${rel%.msr}"
}

sock_for_canonical() {
  local id="$1"
  printf '%s/%s.msr\n' "$WSM_ROOT_RESOLVED" "$id"
}

resolve_current_id() {
  local raw="${MSR_SESSION:-}"
  [[ -n "$raw" ]] || return 1
  canonical_id_for_sock "$raw"
}

require_current_context() {
  resolve_current_id >/dev/null 2>&1 || {
    err "wsm: command requires current WSM session context"
    exit 1
  }
}

current_node_dir() {
  require_current_context
  dirname -- "$MSR_SESSION"
}

list_ids() {
  find "$WSM_ROOT_RESOLVED" \( -type s -o -type f \) -name '*.msr' 2>/dev/null | \
    while IFS= read -r path; do
      canonical_id_for_sock "$path" || true
    done | LC_ALL=C sort -u
}

resolve_query() {
  local query="$1"
  mapfile -t ids < <(list_ids)
  [[ ${#ids[@]} -gt 0 ]] || return 1

  local matches=()
  local id base

  for id in "${ids[@]}"; do
    if [[ "$id" == "$query" ]]; then
      printf '%s\n' "$id"
      return 0
    fi
  done

  for id in "${ids[@]}"; do
    base="${id##*/}"
    if [[ "$base" == "$query" ]]; then
      matches+=("$id")
    fi
  done
  if [[ ${#matches[@]} -eq 1 ]]; then
    printf '%s\n' "${matches[0]}"
    return 0
  elif [[ ${#matches[@]} -gt 1 ]]; then
    printf '%s\n' "${matches[@]}"
    return 2
  fi

  return 1
}

attach_canonical() {
  local id="$1"
  "$DSM_BIN" --cwd "$(dirname -- "$(sock_for_canonical "$id")")" attach "$(basename -- "$id")"
}

status_canonical() {
  local id="$1"
  "$DSM_BIN" --cwd "$(dirname -- "$(sock_for_canonical "$id")")" status "$(basename -- "$id")"
}

exists_canonical() {
  local id="$1"
  "$DSM_BIN" --cwd "$(dirname -- "$(sock_for_canonical "$id")")" exists "$(basename -- "$id")"
}

terminate_canonical() {
  local id="$1"
  local sig="${2:-}"
  if [[ -n "$sig" ]]; then
    "$DSM_BIN" --cwd "$(dirname -- "$(sock_for_canonical "$id")")" terminate "$(basename -- "$id")" "$sig"
  else
    "$DSM_BIN" --cwd "$(dirname -- "$(sock_for_canonical "$id")")" terminate "$(basename -- "$id")"
  fi
}

create_canonical() {
  local id="$1"
  local dir name
  dir="$(dirname -- "$(sock_for_canonical "$id")")"
  name="$(basename -- "$id")"
  mkdir -p "$dir"

  if [[ $# -gt 1 ]]; then
    shift
    env WSM_ROOT="$WSM_ROOT_RESOLVED" WSM_MENU_KEY="$MENU_KEY_OVERRIDE" \
      "$DSM_BIN" --cwd "$dir" create -a "$name" -- "$@"
  else
    env WSM_ROOT="$WSM_ROOT_RESOLVED" WSM_MENU_KEY="$MENU_KEY_OVERRIDE" \
      "$DSM_BIN" --cwd "$dir" create -a "$name"
  fi
}

local_nav_delegate() {
  local op="$1"
  local node_dir
  node_dir="$(current_node_dir)"
  "$DSM_BIN" --cwd "$node_dir" "$op"
}

parent_id_of() {
  local id="$1"
  [[ "$id" == */* ]] || return 1
  printf '%s\n' "${id%/*}"
}

direct_child_ids_of() {
  local current_id="$1"
  local prefix="$current_id/"
  local id rest
  while IFS= read -r id; do
    [[ "$id" == "$prefix"* ]] || continue
    rest="${id#"$prefix"}"
    [[ -n "$rest" ]] || continue
    [[ "$rest" == */* ]] && continue
    printf '%s\n' "$id"
  done < <(list_ids)
}

nav_in() {
  local current_id child_id
  current_id="$(resolve_current_id)" || { err "wsm: in requires current WSM session context"; exit 1; }
  child_id="$(direct_child_ids_of "$current_id" | LC_ALL=C sort | head -n 1)"
  [[ -n "$child_id" ]] || { err "wsm: no direct child session under: $current_id"; exit 1; }
  attach_canonical "$child_id"
}

nav_out() {
  local current_id parent_id
  current_id="$(resolve_current_id)" || { err "wsm: out requires current WSM session context"; exit 1; }
  parent_id="$(parent_id_of "$current_id")" || { err "wsm: already at workspace root boundary: $current_id"; exit 1; }
  exists_canonical "$parent_id" >/dev/null 2>&1 || { err "wsm: no exact direct parent session exists for: $current_id"; exit 1; }
  attach_canonical "$parent_id"
}

if [[ $# -lt 1 ]]; then
  if cid="$(resolve_current_id 2>/dev/null)"; then
    nested_usage "$cid" "$WSM_ROOT_RESOLVED"
  else
    usage
  fi
  exit 1
fi

cmd="$1"
shift || true

case "$cmd" in
  help|h|-h|--help)
    if cid="$(resolve_current_id 2>/dev/null)"; then
      nested_usage "$cid" "$WSM_ROOT_RESOLVED"
    else
      usage
    fi
    ;;

  c|create)
    [[ $# -ge 1 ]] || { err "wsm: create requires <target>"; exit 1; }
    target="$1"
    [[ "$target" != -* ]] || { err "wsm: create requires <target>; got flag-like value: $target"; exit 1; }
    shift || true

    if [[ ${1:-} == -- ]]; then
      shift || true
      create_canonical "$target" "$@"
    else
      create_canonical "$target"
    fi
    ;;

  a|attach)
    [[ $# -ge 1 ]] || { err "wsm: attach requires <target-or-query>"; exit 1; }
    query="$1"
    set +e
    resolved="$(resolve_query "$query")"
    rc=$?
    set -e
    if [[ $rc -eq 0 ]]; then
      attach_canonical "$resolved"
    elif [[ $rc -eq 2 ]]; then
      err "wsm: ambiguous query: $query"
      printf '%s\n' "$resolved"
      exit 1
    else
      err "wsm: no match for query: $query"
      exit 1
    fi
    ;;

  d|detach)
    local_nav_delegate detach
    ;;

  current|u)
    cid="$(resolve_current_id)" || { err "wsm: no current session and no WSM context"; exit 1; }
    out "$cid"
    ;;

  status)
    if [[ $# -ge 1 ]]; then
      query="$1"
      set +e
      resolved="$(resolve_query "$query")"
      rc=$?
      set -e
      if [[ $rc -eq 0 ]]; then
        status_canonical "$resolved"
      elif [[ $rc -eq 2 ]]; then
        err "wsm: ambiguous query: $query"
        printf '%s\n' "$resolved"
        exit 1
      else
        err "wsm: no match for query: $query"
        exit 1
      fi
    else
      cid="$(resolve_current_id)" || { err "wsm: no target and no current WSM context"; exit 1; }
      status_canonical "$cid"
    fi
    ;;

  e|exists)
    if [[ $# -ge 1 ]]; then
      query="$1"
      set +e
      resolved="$(resolve_query "$query")"
      rc=$?
      set -e
      if [[ $rc -eq 0 ]]; then
        exists_canonical "$resolved"
      elif [[ $rc -eq 2 ]]; then
        err "wsm: ambiguous query: $query"
        printf '%s\n' "$resolved"
        exit 1
      else
        err "wsm: no match for query: $query"
        exit 1
      fi
    else
      cid="$(resolve_current_id)" || { err "wsm: no target and no current WSM context"; exit 1; }
      exists_canonical "$cid"
    fi
    ;;

  terminate|t)
    sig=""
    query=""

    case "${1:-}" in
      "")
        cid="$(resolve_current_id)" || { err "wsm: terminate requires <target-or-query> when no current WSM context exists"; exit 1; }
        terminate_canonical "$cid"
        ;;
      TERM|INT|KILL)
        cid="$(resolve_current_id)" || { err "wsm: terminate signal-only form requires current WSM context"; exit 1; }
        terminate_canonical "$cid" "$1"
        ;;
      -f|--force)
        cid="$(resolve_current_id)" || { err "wsm: terminate --force requires current WSM context or an explicit target"; exit 1; }
        terminate_canonical "$cid" KILL
        ;;
      *)
        query="$1"
        shift || true
        case "${1:-}" in
          "") sig="" ;;
          TERM|INT|KILL) sig="$1" ;;
          -f|--force) sig="KILL" ;;
          *) err "wsm: terminate only accepts TERM, INT, KILL, or --force after a target"; exit 1 ;;
        esac
        set +e
        resolved="$(resolve_query "$query")"
        rc=$?
        set -e
        if [[ $rc -eq 0 ]]; then
          terminate_canonical "$resolved" "$sig"
        elif [[ $rc -eq 2 ]]; then
          err "wsm: ambiguous query: $query"
          printf '%s\n' "$resolved"
          exit 1
        else
          err "wsm: no match for query: $query"
          exit 1
        fi
        ;;
    esac
    ;;

  f|first)
    local_nav_delegate first
    ;;

  l|last)
    local_nav_delegate last
    ;;

  p|prev)
    local_nav_delegate prev
    ;;

  n|next)
    local_nav_delegate next
    ;;

  in|i)
    nav_in
    ;;

  out|o)
    nav_out
    ;;

  ls|list|s)
    list_ids
    ;;

  root|r)
    out "$WSM_ROOT_RESOLVED"
    ;;

  menu|m)
    exec "$WSM_MENU_BIN" --root "$WSM_ROOT_RESOLVED"
    ;;

  *)
    err "wsm: unknown command: $cmd"
    usage
    exit 1
    ;;
esac


