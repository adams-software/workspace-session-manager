#!/usr/bin/env bash
set -euo pipefail

resolve_source_path() {
  local src="${BASH_SOURCE[0]}"
  while [[ -L "$src" ]]; do
    local dir
    dir="$(cd -- "$(dirname -- "$src")" && pwd)"
    src="$(readlink -- "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  cd -- "$(dirname -- "$src")" && pwd
}

SCRIPT_DIR="$(resolve_source_path)"
if [[ -x "$SCRIPT_DIR/msr" ]]; then
  BIN_DIR="$SCRIPT_DIR"
  MSR_BIN="${MSR_BIN:-$SCRIPT_DIR/msr}"
  WSM_MENU_BIN="${WSM_MENU_BIN:-$SCRIPT_DIR/wsm_menu}"
  REPO_ROOT="${MSR_REPO_ROOT:-}"
else
  REPO_ROOT="${MSR_REPO_ROOT:-$(cd -- "$SCRIPT_DIR/../.." && pwd)}"
  BIN_DIR="${MSR_BIN_DIR:-$REPO_ROOT/zig-out/bin}"
  MSR_BIN="${MSR_BIN:-$BIN_DIR/msr}"
  WSM_MENU_BIN="${WSM_MENU_BIN:-$REPO_ROOT/wsm/scripts/wsm_menu}"
fi
ALT_BIN="${ALT_BIN:-$BIN_DIR/alt}"
VPTY_BIN="${VPTY_BIN:-$BIN_DIR/vpty}"

err() { printf '%s\n' "$*" >&2; }
out() { printf '%s\n' "$*"; }

menu_key_value() {
  if [[ -n "$MENU_KEY_OVERRIDE" ]]; then
    printf '%s\n' "$MENU_KEY_OVERRIDE"
  elif [[ -n "${WSM_MENU_KEY:-}" ]]; then
    printf '%s\n' "$WSM_MENU_KEY"
  else
    printf '%s\n' 'ctrl-g'
  fi
}

usage_body() {
  cat <<'EOU'
NAME
  wsm - workspace session manager

USAGE
  [WSM_ROOT=<path>] [WSM_MENU_KEY=<spec>] wsm [--root <path>] [--menu-key <spec>] <command> [args]

COMMANDS
  [c]reate <target> [-- <cmd...>]        create and attach to a workspace session
  [a]ttach <target-or-query>             attach to a resolved workspace session
  [d]etach                               detach the current session
  c[u]rrent                              print the current canonical workspace id
  [e]xists [target-or-query]             test whether a session is reachable
  [t]erminate [target-or-query] [signal] send TERM, INT, or KILL to a session
  [f]irst | [l]ast | [p]rev | [n]ext     navigate sessions within the current directory
  [i]n                                   attach to the first lexical direct child session
  [o]ut                                  attach to the exact direct parent session
  ls, li[s]t                             list canonical ids under the workspace root
  [r]oot                                 print the resolved workspace root
  [m]enu                                 open the interactive workspace menu
  [h]elp                                 show this help

ROOT
  wsm requires an explicit workspace root via --root <path> or WSM_ROOT.
  It does not silently fall back to the current directory.

MENU KEY
  wsm passes the menu hotkey through to alt using alt's key-spec format.
  Default: ctrl-g
  Override with --menu-key <spec> or WSM_MENU_KEY.

RESOLUTION
  Queries resolve in this order:
    1. exact canonical id match
    2. exact basename match if unique
    3. otherwise print candidates and exit nonzero

HELP
  Run `wsm` or `wsm --help` for this screen.
  Use shell completion for fast canonical-id expansion.
  If you are in a session, you will see it listed under `SESSION:`
EOU
}

usage() {
  usage_body
  cat <<EOF

WORKSPACE:
  $WSM_ROOT_RESOLVED

MENU KEY:
  $(menu_key_value)

EOF
}

nested_usage() {
  usage_body
  cat <<EOF

WORKSPACE:
  $WSM_ROOT_RESOLVED
EOF
  local current_id="$1"
  local root="$2"
  cat <<EOF2

SESSION:
  $current_id

MENU KEY:
  $(menu_key_value)

EOF2
}

ROOT_OVERRIDE=""
MENU_KEY_OVERRIDE=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --root=*)
      ROOT_OVERRIDE="${1#--root=}"
      shift
      ;;
    --root)
      ROOT_OVERRIDE="$2"
      shift 2
      ;;
    --menu-key=*)
      MENU_KEY_OVERRIDE="${1#--menu-key=}"
      shift
      ;;
    --menu-key)
      MENU_KEY_OVERRIDE="$2"
      shift 2
      ;;
    *)
      break
      ;;
  esac
done

expand_path() {
  local p="${1:-}"
  case "$p" in
    "~") printf '%s\n' "$HOME" ;;
    "~/"*) printf '%s/%s\n' "$HOME" "${p#~/}" ;;
    *) printf '%s\n' "$p" ;;
  esac
}
expand_user_path() {
  local p="${1:-}"
  case "$p" in
    "~")
      p="$HOME"
      ;;
    "~/"*)
      p="$HOME/${p#\~/}"
      ;;
  esac
  printf '%s\n' "$p"
}

normalize_path() {
  local p
  p="$(expand_user_path "${1:-}")"

  if [[ "$p" != /* ]]; then
    p="$PWD/$p"
  fi

  printf '%s\n' "$p"
}

resolve_root() {
  if [[ -n "$ROOT_OVERRIDE" ]]; then
    normalize_path "$ROOT_OVERRIDE"
    return
  fi
  if [[ -n "${WSM_ROOT:-}" ]]; then
    normalize_path "$WSM_ROOT"
    return
  fi
  return 1
}

require_root() {
  err "wsm: workspace root is required"
  err "set WSM_ROOT or pass --root <path>"
  err "example: wsm --root ~/code create -a api/dev -- bash"
  exit 1
}

WSM_ROOT_RESOLVED="$(resolve_root)" || require_root
[[ -d "$WSM_ROOT_RESOLVED" ]] || { err "wsm: root directory does not exist: $WSM_ROOT_RESOLVED"; exit 1; }

canonical_id_for_sock() {
  local sock="$1"
  local rel
  rel="${sock#$WSM_ROOT_RESOLVED/}"
  [[ "$rel" != "$sock" ]] || {
    if [[ "$sock" == "$WSM_ROOT_RESOLVED"/*.msr ]]; then
      rel="$(basename -- "$sock")"
    else
      return 1
    fi
  }
  [[ "$rel" == *.msr ]] || return 1
  printf '%s\n' "${rel%.msr}"
}

sock_for_canonical() {
  local id="$1"
  printf '%s/%s.msr\n' "$WSM_ROOT_RESOLVED" "$id"
}

canonical_id_is_valid() {
  local id="$1"
  [[ -n "$id" ]] || return 1
  [[ "$id" != -* ]] || return 1
  [[ "$id" != /* ]] || return 1
  [[ "$id" != */ ]] || return 1
  [[ "$id" != *//* ]] || return 1
  [[ "$id" != *"/./"* ]] || return 1
  [[ "$id" != *"/../"* ]] || return 1
  [[ "$id" != "." ]] || return 1
  [[ "$id" != ".." ]] || return 1
  [[ "$id" != ./* ]] || return 1
  [[ "$id" != ../* ]] || return 1
  [[ "$id" != */. ]] || return 1
  [[ "$id" != */.. ]] || return 1
  return 0
}

resolve_current_id() {
  local raw="${MSR_SESSION:-}"
  [[ -n "$raw" ]] || return 1
  canonical_id_for_sock "$raw"
}

require_current_context() {
  resolve_current_id >/dev/null 2>&1 || {
    err "wsm: command requires current WSM session context"
    exit 1
  }
}

current_node_dir() {
  require_current_context
  dirname -- "$MSR_SESSION"
}

list_ids() {
  find "$WSM_ROOT_RESOLVED" \( -type s -o -type f \) -name '*.msr' 2>/dev/null | \
    while IFS= read -r path; do
      canonical_id_for_sock "$path" || true
    done | LC_ALL=C sort -u
}

resolve_query() {
  local query="$1"
  mapfile -t ids < <(list_ids)
  [[ ${#ids[@]} -gt 0 ]] || return 1

  local matches=()
  local id base

  for id in "${ids[@]}"; do
    if [[ "$id" == "$query" ]]; then
      printf '%s\n' "$id"
      return 0
    fi
  done

  for id in "${ids[@]}"; do
    base="${id##*/}"
    if [[ "$base" == "$query" ]]; then
      matches+=("$id")
    fi
  done
  if [[ ${#matches[@]} -eq 1 ]]; then
    printf '%s\n' "${matches[0]}"
    return 0
  elif [[ ${#matches[@]} -gt 1 ]]; then
    printf '%s\n' "${matches[@]}"
    return 2
  fi

  return 1
}

launch_stack_argv() {
  local -a argv
  argv=("$ALT_BIN")
  if [[ -n "${MENU_KEY_OVERRIDE:-}" ]]; then
    argv+=(--key "$MENU_KEY_OVERRIDE")
  elif [[ -n "${WSM_MENU_KEY:-}" ]]; then
    argv+=(--key "$WSM_MENU_KEY")
  fi
  argv+=(--run "$WSM_MENU_BIN" --signal-2 TERM -- "$VPTY_BIN" --)
  printf '%s\n' "${argv[@]}"
}

attach_canonical() {
  local id="$1"
  local sock
  sock="$(sock_for_canonical "$id")"
  if [[ -n "${MSR_SESSION:-}" ]]; then
    "$MSR_BIN" attach "$sock"
  else
    "$MSR_BIN" attach "$sock" --force
  fi
}

status_canonical() {
  local id="$1"
  "$MSR_BIN" status "$(sock_for_canonical "$id")"
}

exists_canonical() {
  local id="$1"
  "$MSR_BIN" exists "$(sock_for_canonical "$id")"
}

terminate_canonical() {
  local id="$1"
  local sig="${2:-}"
  if [[ -n "$sig" ]]; then
    "$MSR_BIN" terminate "$(sock_for_canonical "$id")" "$sig"
  else
    "$MSR_BIN" terminate "$(sock_for_canonical "$id")"
  fi
}

create_canonical() {
  local id="$1"
  local sock dir
  local -a launch_stack
  sock="$(sock_for_canonical "$id")"
  dir="$(dirname -- "$sock")"
  mkdir -p "$dir"
  mapfile -t launch_stack < <(launch_stack_argv)

  if [[ $# -gt 1 ]]; then
    shift
    env WSM_ROOT="$WSM_ROOT_RESOLVED" WSM_MENU_KEY="${MENU_KEY_OVERRIDE:-${WSM_MENU_KEY:-}}" \
      "$MSR_BIN" create -a "$sock" -- "${launch_stack[@]}" "$@"
  else
    env WSM_ROOT="$WSM_ROOT_RESOLVED" WSM_MENU_KEY="${MENU_KEY_OVERRIDE:-${WSM_MENU_KEY:-}}" \
      "$MSR_BIN" create -a "$sock" -- "${launch_stack[@]}" "$SHELL" -i
  fi
}

parent_id_of() {
  local id="$1"
  [[ "$id" == */* ]] || return 1
  printf '%s\n' "${id%/*}"
}

direct_child_ids_of() {
  local current_id="$1"
  local prefix="$current_id/"
  local id rest
  while IFS= read -r id; do
    [[ "$id" == "$prefix"* ]] || continue
    rest="${id#"$prefix"}"
    [[ -n "$rest" ]] || continue
    [[ "$rest" == */* ]] && continue
    printf '%s\n' "$id"
  done < <(list_ids)
}

dir_session_names() {
  local dir="$1"
  find "$dir" -maxdepth 1 \( -type s -o -type f \) -name '*.msr' -printf '%f\n' 2>/dev/null | \
    sed 's/\.msr$//' | LC_ALL=C sort
}

resolve_nav_target() {
  local op="$1"
  local current_id current_dir child_id parent_id current_name
  local -a names
  local i last

  case "$op" in
    first)
      current_dir="$(current_node_dir)" || return 1
      mapfile -t names < <(dir_session_names "$current_dir")
      [[ ${#names[@]} -gt 0 ]] || return 1
      canonical_id_for_sock "$current_dir/${names[0]}.msr"
      ;;
    last)
      current_dir="$(current_node_dir)" || return 1
      mapfile -t names < <(dir_session_names "$current_dir")
      [[ ${#names[@]} -gt 0 ]] || return 1
      canonical_id_for_sock "$current_dir/${names[$((${#names[@]} - 1))]}.msr"
      ;;
    prev|next)
      current_dir="$(current_node_dir)" || return 1
      current_name="${MSR_SESSION##*/}"
      current_name="${current_name%.msr}"
      mapfile -t names < <(dir_session_names "$current_dir")
      [[ ${#names[@]} -gt 0 ]] || return 1
      last=$((${#names[@]} - 1))
      for ((i=0; i<${#names[@]}; i++)); do
        if [[ "${names[$i]}" == "$current_name" ]]; then
          if [[ "$op" == "prev" ]]; then
            if [[ $i -gt 0 ]]; then
              canonical_id_for_sock "$current_dir/${names[$((i-1))]}.msr"
            else
              canonical_id_for_sock "$current_dir/${names[$last]}.msr"
            fi
          else
            if [[ $i -lt $last ]]; then
              canonical_id_for_sock "$current_dir/${names[$((i+1))]}.msr"
            else
              canonical_id_for_sock "$current_dir/${names[0]}.msr"
            fi
          fi
          return 0
        fi
      done
      return 1
      ;;
    in)
      current_id="$(resolve_current_id)" || return 1
      child_id="$(direct_child_ids_of "$current_id" | LC_ALL=C sort | head -n 1)"
      [[ -n "$child_id" ]] || return 1
      printf '%s\n' "$child_id"
      ;;
    out)
      current_id="$(resolve_current_id)" || return 1
      parent_id="$(parent_id_of "$current_id")" || return 1
      exists_canonical "$parent_id" >/dev/null 2>&1 || return 1
      printf '%s\n' "$parent_id"
      ;;
    *)
      return 2
      ;;
  esac
}

nav_in() {
  local target
  target="$(resolve_nav_target in)" || { err "wsm: no direct child session under current session"; exit 1; }
  attach_canonical "$target"
}

nav_out() {
  local current_id target
  current_id="$(resolve_current_id)" || { err "wsm: out requires current WSM session context"; exit 1; }
  target="$(resolve_nav_target out)" || {
    parent_id_of "$current_id" >/dev/null 2>&1 || { err "wsm: already at workspace root boundary: $current_id"; exit 1; }
    err "wsm: no exact direct parent session exists for: $current_id"
    exit 1
  }
  attach_canonical "$target"
}

if [[ $# -lt 1 ]]; then
  if cid="$(resolve_current_id 2>/dev/null)"; then
    nested_usage "$cid" "$WSM_ROOT_RESOLVED"
  else
    usage
  fi
  exit 1
fi

cmd="$1"
shift || true

case "$cmd" in
  help|h|-h|--help)
    if cid="$(resolve_current_id 2>/dev/null)"; then
      nested_usage "$cid" "$WSM_ROOT_RESOLVED"
    else
      usage
    fi
    ;;

  c|create)
    [[ $# -ge 1 ]] || { err "wsm: create requires <target>"; exit 1; }
    target="$1"
    canonical_id_is_valid "$target" || { err "wsm: invalid canonical target: $target"; exit 1; }
    shift || true

    if [[ ${1:-} == -- ]]; then
      shift || true
      create_canonical "$target" "$@"
    else
      create_canonical "$target"
    fi
    ;;

  a|attach)
    [[ $# -ge 1 ]] || { err "wsm: attach requires <target-or-query>"; exit 1; }
    query="$1"
    set +e
    resolved="$(resolve_query "$query")"
    rc=$?
    set -e
    if [[ $rc -eq 0 ]]; then
      attach_canonical "$resolved"
    elif [[ $rc -eq 2 ]]; then
      err "wsm: ambiguous query: $query"
      printf '%s\n' "$resolved"
      exit 1
    else
      err "wsm: no match for query: $query"
      exit 1
    fi
    ;;

  d|detach)
    "$MSR_BIN" detach
    ;;

  current|u)
    cid="$(resolve_current_id)" || { err "wsm: no current session and no WSM context"; exit 1; }
    out "$cid"
    ;;

  status)
    if [[ $# -ge 1 ]]; then
      query="$1"
      set +e
      resolved="$(resolve_query "$query")"
      rc=$?
      set -e
      if [[ $rc -eq 0 ]]; then
        status_canonical "$resolved"
      elif [[ $rc -eq 2 ]]; then
        err "wsm: ambiguous query: $query"
        printf '%s\n' "$resolved"
        exit 1
      else
        err "wsm: no match for query: $query"
        exit 1
      fi
    else
      cid="$(resolve_current_id)" || { err "wsm: no target and no current WSM context"; exit 1; }
      status_canonical "$cid"
    fi
    ;;

  e|exists)
    if [[ $# -ge 1 ]]; then
      query="$1"
      set +e
      resolved="$(resolve_query "$query")"
      rc=$?
      set -e
      if [[ $rc -eq 0 ]]; then
        exists_canonical "$resolved"
      elif [[ $rc -eq 2 ]]; then
        err "wsm: ambiguous query: $query"
        printf '%s\n' "$resolved"
        exit 1
      else
        err "wsm: no match for query: $query"
        exit 1
      fi
    else
      cid="$(resolve_current_id)" || { err "wsm: no target and no current WSM context"; exit 1; }
      exists_canonical "$cid"
    fi
    ;;

  terminate|t)
    sig=""
    query=""

    case "${1:-}" in
      "")
        cid="$(resolve_current_id)" || { err "wsm: terminate requires <target-or-query> when no current WSM context exists"; exit 1; }
        terminate_canonical "$cid"
        ;;
      TERM|INT|KILL)
        cid="$(resolve_current_id)" || { err "wsm: terminate signal-only form requires current WSM context"; exit 1; }
        terminate_canonical "$cid" "$1"
        ;;
      -f|--force)
        cid="$(resolve_current_id)" || { err "wsm: terminate --force requires current WSM context or an explicit target"; exit 1; }
        terminate_canonical "$cid" KILL
        ;;
      *)
        query="$1"
        shift || true
        case "${1:-}" in
          "") sig="" ;;
          TERM|INT|KILL) sig="$1" ;;
          -f|--force) sig="KILL" ;;
          *) err "wsm: terminate only accepts TERM, INT, KILL, or --force after a target"; exit 1 ;;
        esac
        set +e
        resolved="$(resolve_query "$query")"
        rc=$?
        set -e
        if [[ $rc -eq 0 ]]; then
          terminate_canonical "$resolved" "$sig"
        elif [[ $rc -eq 2 ]]; then
          err "wsm: ambiguous query: $query"
          printf '%s\n' "$resolved"
          exit 1
        else
          err "wsm: no match for query: $query"
          exit 1
        fi
        ;;
    esac
    ;;

  resolve)
    [[ $# -ge 1 ]] || exit 1
    resolve_nav_target "$1"
    ;;

  f|first)
    target="$(resolve_nav_target first)" || { err "wsm: no sessions in current directory"; exit 1; }
    attach_canonical "$target"
    ;;

  l|last)
    target="$(resolve_nav_target last)" || { err "wsm: no sessions in current directory"; exit 1; }
    attach_canonical "$target"
    ;;

  p|prev)
    target="$(resolve_nav_target prev)" || { err "wsm: no previous session in current directory"; exit 1; }
    attach_canonical "$target"
    ;;

  n|next)
    target="$(resolve_nav_target next)" || { err "wsm: no next session in current directory"; exit 1; }
    attach_canonical "$target"
    ;;

  in|i)
    nav_in
    ;;

  out|o)
    nav_out
    ;;

  ls|list|s)
    list_ids
    ;;

  root|r)
    out "$WSM_ROOT_RESOLVED"
    ;;

  menu|m)
    exec "$WSM_MENU_BIN" --root "$WSM_ROOT_RESOLVED"
    ;;

  *)
    err "wsm: unknown command: $cmd"
    usage
    exit 1
    ;;
esac


